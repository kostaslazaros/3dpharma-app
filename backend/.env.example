# OpenAI API Key (required for AI chat functionality)
OPENAI_API_KEY=openai_api_key_here

# Anthropic API Key (optional, for Claude models)
ANTHROPIC_API_KEY=anthropic_api_key_here

# Enable OpenFDA data loading (set to 'false' to disable)
ENABLE_OPENFDA_DATA=true

# Clinical co-administration AI agent (tool-using).
# Provider: 'openai' (default, cheapest) or 'anthropic'.
COADMIN_LLM_PROVIDER=openai
# Model: default gpt-4o-mini (openai) or claude-haiku-4-5 (anthropic).
# Leave unset to use the provider default.
COADMIN_LLM_MODEL=gpt-4o-mini

# Optional openFDA API key — raises the rate limit for
# scripts/build_condition_labels.py (not required for runtime).
OPENFDA_API_KEY=

# CORS origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server configuration
HOST=0.0.0.0
PORT=8000
